# ── Pre-deployed VM IPs ─────────────────────────────────
# First master_ip becomes the initial RKE2 server.
# Additional masters join as control-plane+etcd.
master_ips = ["10.0.1.10"]
worker_ips = ["10.0.1.20", "10.0.1.21"]

# ── SSH Access ──────────────────────────────────────────
ssh_user             = "ubuntu"
ssh_private_key_path = "~/.ssh/rke2-key"

# Bastion host (leave empty for direct SSH access)
bastion_ip = "80.xxx.xxx.xxx"

# ── Cluster Config ──────────────────────────────────────
cluster_name  = "rke2-join"
cluster_token = "your-secure-random-token"
cni_plugin    = "kube-ovn"   # "cilium" or "kube-ovn"
